{{- /* CHANGED: Scoped to the current language's pages instead of the global site collection */ -}}
{{- $pages := where .Site.RegularPages "Section" "nyheter" -}}
{{- $pages = $pages.ByDate.Reverse -}}
{{ `<?xml version="1.0" encoding="utf-8" standalone="yes" ?>` | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>{{ .Site.Title }}</title>
    <link>{{ .Permalink }}</link>
    <description>Recent content on {{ .Site.Title }}</description>
    <generator>Hugo -- gohugo.io</generator>
    {{- /* Natively outputs 'sv' for the Swedish feed and your new languageCode configuration for the English one */ -}}
    {{- with .Site.LanguageCode }}
    <language>{{ . }}</language>
    {{- end }}
    {{- if not .Date.IsZero }}
    <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- end }}
    {{- with .OutputFormats.Get "RSS" }}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end }}
    {{- range $pages }}
    {{- $_ := .Content }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ with .Params.description }}{{ . }}{{ else }}{{ .Summary | plainify }}{{ end }}</description>
      {{- with .Store.Get "discord" }}
      <discord>{{ . }}</discord>
      {{- end }}
    </item>
    {{- end }}
  </channel>
</rss>